NEXT_PUBLIC_API_URL=http://localhost:5001

# --- PostgreSQL (única fuente de verdad de credenciales; compose los lee de aquí) ---
POSTGRES_USER=idc_admin
POSTGRES_PASSWORD=cambiar_esta_clave
POSTGRES_DB=innovadataco_001

# Dev fuera de docker (PM2): host localhost, puerto 5435.
# Dentro de compose NO se usa esta variable: el compose deriva db:5432 del trío POSTGRES_*.
DATABASE_URL=postgresql://idc_admin:cambiar_esta_clave@localhost:5435/innovadataco_001?schema=public

OPENAI_APIKEY=

# Vacío => dentro de compose aplica el default http://host.docker.internal:11434.
# En dev fuera de docker el fallback del código es http://localhost:11434 (FR-010).
OLLAMA_BASEURL=

# Bandera Secure de la cookie de sesión (spec 004, FR-004 / D-036).
# Característica de DESPLIEGUE, no parámetro de negocio: se lee solo de esta variable,
# nunca de ModuleSetting ni de la UI, y no depende de NODE_ENV.
# Default: true (segura). Solo el valor exacto "false" la desactiva.
# Apágala únicamente si sirves la app por http (p. ej. http://localhost en desarrollo):
# Safari descarta las cookies Secure sobre http y la sesión no persiste.
AUTH_COOKIE_SECURE=true

ENCRYPTION_KEY=
JWT_SECRET=
ALLOWED_DEV_ORIGIN=
