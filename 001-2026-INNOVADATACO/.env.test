# Entorno EXCLUSIVO de la suite de tests (spec 002, FR-001).
# Todos los valores son DUMMY y están versionados a propósito: NO son secretos.
# La suite no debe depender del .env local del desarrollador ni de una BD viva.

# 32+ caracteres para satisfacer la validación de src/lib/auth.ts
JWT_SECRET=test_jwt_secret_dummy_no_es_secreto_real_0123456789
ENCRYPTION_KEY=00000000000000000000000000000000

# Solo para que PrismaClient pueda instanciarse. Ningún test abre conexión:
# todos mockean @/lib/prisma (ver src/test/prismaMock.ts).
DATABASE_URL=postgresql://test:test@localhost:5435/test_db?schema=public

OLLAMA_BASEURL=http://localhost:11434
NODE_ENV=test
