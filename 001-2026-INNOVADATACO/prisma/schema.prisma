generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DocumentoOficial {
  id              String             @id @default(cuid())
  titulo          String
  tipo            String
  sector          String?
  entidad         String
  fechaExpedicion DateTime?
  numero          String?
  archivoUrl      String
  contenidoTexto  String             @default("")
  resumen         String             @default("")
  proposito       String             @default("")
  actores         String             @default("")
  motivacion      String             @default("")
  resuelve        String             @default("")
  jerarquiaNivel  Int                @default(0)
  padreId         String?
  status          String             @default("pending")
  activo          Boolean            @default(true)
  aiModelId       String?
  processingError String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  padre           DocumentoOficial?  @relation("JerarquiaDocumentos", fields: [padreId], references: [id])
  hijos           DocumentoOficial[] @relation("JerarquiaDocumentos")
  chunks          DocumentoChunk[]

  @@index([tipo])
  @@index([jerarquiaNivel])
  @@index([status])
  @@index([activo])
}

model AiModel {
  id        String     @id @default(cuid())
  name      String
  provider  String
  scope     String     @default("local")
  baseUrl   String?
  apiKey    String?
  modelPath String
  active    Boolean    @default(false)
  config    String     @default("{}")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  audits    AuditLog[]
  moduleSettings ModuleSetting[]

  @@index([provider])
  @@index([active])
  @@index([scope])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  userId     String?
  status     String
  message    String
  metadata   String   @default("{}")
  latencyMs  Int?
  createdAt  DateTime @default(now())
  aiModelId  String?
  aiModel    AiModel? @relation(fields: [aiModelId], references: [id])

  @@index([action])
  @@index([status])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentApi {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  module      String
  submodule   String
  category    String
  method      String
  path        String
  authType    String   @default("none")
  active      Boolean  @default(true)
  docs        String   @default("{}")
  config      String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([module])
  @@index([submodule])
  @@index([active])
  @@index([category])
}

// Oportunidad (spec 006). Se conserva el nombre técnico `Licitacion` y la tabla
// `licitaciones` (SC-011): "Oportunidad" es el concepto de cara al usuario. La
// licitación pública es UN tipo dentro del catálogo configurable TipoOportunidad.
model Licitacion {
  id            String                @id @default(cuid())
  // numero y fechaApertura pasan a OPCIONALES: su exigencia la fija el `tipo`
  // (banderas configurables), no un if por nombre (§0.7, FR-003).
  numero        String?
  titulo        String
  estadoId      Int
  entidadId     Int?
  tipoId        Int?
  areaIdSala    Int?
  // Cronograma (FR-007): 5 hitos opcionales. `fechaApertura` es el hito "apertura".
  fechaApertura           DateTime?
  fechaPliegosDefinitivos DateTime?
  fechaEntregaPropuesta   DateTime?
  fechaAdjudicacion       DateTime?
  fechaCierre             DateTime?
  ciudadEjecucion String?
  descripcion   String                @default("")
  documentoUrl  String?
  contenido     String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  documentos    LicitacionDocumento[]
  partidas      PartidaPresupuesto[]
  entidad       EntidadLicitacion?    @relation("EntidadesLicitaciones", fields: [entidadId], references: [id])
  estado        LicitacionStatus      @relation(fields: [estadoId], references: [id])
  tipo          TipoOportunidad?      @relation(fields: [tipoId], references: [id])

  // Con numero y fechaApertura opcionales, Postgres permite múltiples NULL: esta
  // unicidad solo ata a las oportunidades que tienen AMBOS (las licitaciones
  // públicas). Es deliberado (FR-006), no accidental.
  @@unique([numero, fechaApertura])
  @@index([estadoId])
  @@index([entidadId])
  @@index([tipoId])
  @@index([createdAt])
  @@map("licitaciones")
}

// Catálogo CONFIGURABLE de tipos de oportunidad (FR-002). Como entidades y estados,
// se administra desde el módulo. Las banderas exige* son la propiedad que decide la
// obligatoriedad de campos por tipo (FR-003), en lugar de nombres de tipo cableados.
model TipoOportunidad {
  id                 Int          @id @default(autoincrement())
  key                String       @unique
  nombreOficial      String
  exigeNumero        Boolean      @default(false)
  exigeFechaApertura Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  oportunidades      Licitacion[]
}

// Presupuesto DESGLOSADO (FR-008): varias partidas por oportunidad, cada una con su
// moneda (no se asume una sola divisa). El total se calcula al leer.
model PartidaPresupuesto {
  id           String     @id @default(cuid())
  licitacionId String
  concepto     String
  monto        Decimal    @db.Decimal(18, 2)
  moneda       String     @default("COP")
  createdAt    DateTime   @default(now())
  licitacion   Licitacion @relation(fields: [licitacionId], references: [id], onDelete: Cascade)

  @@index([licitacionId])
}

model LicitacionDocumento {
  id           String             @id @default(cuid())
  nombre       String
  tipo         String
  contenido    String             @default("")
  fechaInicio  DateTime?
  fechaFin     DateTime?
  fechaCorte   DateTime?
  createdAt    DateTime           @default(now())
  licitacionId String
  entidadId    Int?
  entidad      EntidadLicitacion? @relation("EntidadesDocumentos", fields: [entidadId], references: [id])
  licitacion   Licitacion         @relation(fields: [licitacionId], references: [id], onDelete: Cascade)

  @@unique([tipo, nombre, licitacionId])
}

model EntidadLicitacion {
  id            Int                   @id @default(autoincrement())
  key           String        @unique
  nombreOficial String
  // Información ampliada de la entidad (FR-010): toda opcional para no romper las
  // filas ya sembradas.
  nit           String?
  sitioWeb      String?
  telefono      String?
  direccion     String?
  ciudad        String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  documentos    LicitacionDocumento[] @relation("EntidadesDocumentos")
  licitaciones  Licitacion[]          @relation("EntidadesLicitaciones")
}

model LicitacionStatus {
  id            Int          @id @default(autoincrement())
  key           String       @unique
  nombreOficial String
  createdAt     DateTime     @default(now())
  licitaciones  Licitacion[]
}

model Proyecto {
  id           String   @id @default(cuid())
  codigo       String   @unique
  nombre       String
  cliente      String
  estado       String   @default("active")
  currentPhase String   @default("initiation") @map("current_phase")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entregables Entregable[]
  hitos       HitoProyecto[]
  partidas    PartidaProyecto[]
  recursos    RecursoProyecto[]
  lecciones   LeccionAprendida[]
  riesgos     RiesgoProyecto[]

  @@index([estado])
  @@index([currentPhase])
  @@map("proyectos")
}

/// Entregable de un proyecto PM2 (spec 008, US3). Los cinco campos mínimos los
/// fijó el CEO en /speckit-clarify: nombre, descripción, estado/avance, fecha
/// compromiso y responsable. CASCADE: al borrar el proyecto no quedan huérfanos.
model Entregable {
  id             String    @id @default(cuid())
  proyectoId     String
  nombre         String
  descripcion    String    @default("")
  /// Avance en porcentaje (0-100). La ruta lo valida; aquí solo se guarda.
  avance         Int       @default(0)
  /// Estado libre y corto: "pendiente", "en curso", "entregado"…
  estado         String    @default("pendiente")
  /// Inicio planificado (spec 015): la barra del Gantt va de aquí a
  /// fechaCompromiso. Opcional; los entregables previos usan createdAt.
  fechaInicio     DateTime?
  /// Dependencia fin→inicio (spec 016): id de item del Gantt (p. ej.
  /// "entregable:x" o "hito:y") del que depende. Polimórfico y opcional; una
  /// referencia colgada no genera conflicto.
  dependeDe       String?
  fechaCompromiso DateTime?
  responsable    String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("entregables")
}

/// Hito o actividad del cronograma (spec 008, US4 / FR-011). `fecha` es la del
/// hito; `fechaFin` solo la usan las actividades que abarcan un periodo.
model HitoProyecto {
  id         String    @id @default(cuid())
  proyectoId String
  nombre     String
  fecha      DateTime
  fechaFin   DateTime?
  /// Dependencia fin→inicio (spec 016): id de item del Gantt del que depende.
  dependeDe  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("hitos_proyecto")
}

/// Partida de presupuesto con control de gasto PM2 (spec 008, US5 / FR-012).
/// Replica el patrón de `PartidaPresupuesto` de Oportunidades y lo extiende con
/// planeado vs ejecutado: son dominios distintos, así que se replica el patrón,
/// no la tabla. Que lo ejecutado supere lo planeado es un dato a MOSTRAR
/// (desviación), no algo que impedir.
model PartidaProyecto {
  id             String   @id @default(cuid())
  proyectoId     String
  concepto       String
  montoPlaneado  Decimal  @default(0) @db.Decimal(18, 2)
  montoEjecutado Decimal  @default(0) @db.Decimal(18, 2)
  moneda         String   @default("COP")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("partidas_proyecto")
}

/// Recurso del proyecto (spec 008, US5 / FR-013). El CEO pidió los cuatro datos:
/// nombre y rol, tipo, costo/tarifa y disponibilidad. `rol` puede quedar vacío
/// en los materiales, que no tienen rol (spec, Edge Cases).
model RecursoProyecto {
  id             String   @id @default(cuid())
  proyectoId     String
  nombre         String
  rol            String   @default("")
  tipo           String   @default("humano")
  costo          Decimal  @default(0) @db.Decimal(18, 2)
  disponibilidad String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("recursos_proyecto")
}

/// Lección aprendida (spec 008, US6 / FR-014). Parte del Cierre PM2.
model LeccionAprendida {
  id          String   @id @default(cuid())
  proyectoId  String
  descripcion String
  categoria   String   @default("")
  impacto     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("lecciones_aprendidas")
}

/// Riesgo de un proyecto PM2 (spec 014, US3 / FR-004). Los cinco campos los fijó
/// el CEO (D-073). `probabilidad` y `impacto` son enums textuales validados en la
/// ruta; `estado` decide si el riesgo cuenta como abierto en la cartera
/// (abierto/mitigado sí; cerrado no).
model RiesgoProyecto {
  id           String   @id @default(cuid())
  proyectoId   String
  descripcion  String
  probabilidad String   @default("media")
  impacto      String   @default("medio")
  mitigacion   String   @default("")
  estado       String   @default("abierto")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("riesgos_proyecto")
}

model DocumentoChunk {
  id          String   @id @default(cuid())
  documentoId String
  contenido   String
  orden       Int
  embedding   Unsupported("vector(768)")
  // Modelo + configuración de enriquecimiento con que se generó el vector.
  // Juntos definen a qué espacio vectorial pertenece el fragmento (spec 003,
  // FR-021/FR-026): la búsqueda filtra por ambos y no mezcla espacios.
  embeddingModel String @default("")
  enrichConfig   String @default("none")
  // contenidoFts: tsvector GENERATED sobre `contenido` plano (FR-027). Lo crea la
  // migración en SQL crudo porque Prisma no tipa `tsvector`; no se toca desde la app.
  createdAt   DateTime @default(now())

  documento DocumentoOficial @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([documentoId])
  @@index([embeddingModel, enrichConfig])
}

model ModuleSetting {
  id        String   @id @default(cuid())
  module    String
  settingKey String
  aiModelId String
  updatedAt DateTime @updatedAt

  aiModel AiModel @relation(fields: [aiModelId], references: [id])

  @@unique([module, settingKey])
  @@index([module])
  @@index([settingKey])
}
