generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DocumentoOficial {
  id              String             @id @default(cuid())
  titulo          String
  tipo            String
  sector          String?
  entidad         String
  fechaExpedicion DateTime?
  numero          String?
  archivoUrl      String
  contenidoTexto  String             @default("")
  resumen         String             @default("")
  proposito       String             @default("")
  actores         String             @default("")
  motivacion      String             @default("")
  resuelve        String             @default("")
  jerarquiaNivel  Int                @default(0)
  padreId         String?
  status          String             @default("pending")
  activo          Boolean            @default(true)
  aiModelId       String?
  processingError String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  padre           DocumentoOficial?  @relation("JerarquiaDocumentos", fields: [padreId], references: [id])
  hijos           DocumentoOficial[] @relation("JerarquiaDocumentos")
  chunks          DocumentoChunk[]

  @@index([tipo])
  @@index([jerarquiaNivel])
  @@index([status])
  @@index([activo])
}

model AiModel {
  id        String     @id @default(cuid())
  name      String
  provider  String
  scope     String     @default("local")
  baseUrl   String?
  apiKey    String?
  modelPath String
  active    Boolean    @default(false)
  config    String     @default("{}")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  audits    AuditLog[]

  @@index([provider])
  @@index([active])
  @@index([scope])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  userId     String?
  status     String
  message    String
  metadata   String   @default("{}")
  latencyMs  Int?
  createdAt  DateTime @default(now())
  aiModelId  String?
  aiModel    AiModel? @relation(fields: [aiModelId], references: [id])

  @@index([action])
  @@index([status])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentApi {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  module      String
  submodule   String
  category    String
  method      String
  path        String
  authType    String   @default("none")
  active      Boolean  @default(true)
  docs        String   @default("{}")
  config      String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([module])
  @@index([submodule])
  @@index([active])
  @@index([category])
}

model Licitacion {
  id            String                @id @default(cuid())
  numero        String
  titulo        String
  estadoId      Int
  entidadId     Int?
  areaIdSala    Int?
  fechaApertura DateTime
  descripcion   String                @default("")
  documentoUrl  String?
  contenido     String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  documentos    LicitacionDocumento[]
  entidad       EntidadLicitacion?    @relation("EntidadesLicitaciones", fields: [entidadId], references: [id])
  estado        LicitacionStatus      @relation(fields: [estadoId], references: [id])

  @@unique([numero, fechaApertura])
  @@index([estadoId])
  @@index([entidadId])
  @@index([createdAt])
  @@map("licitaciones")
}

model LicitacionDocumento {
  id           String             @id @default(cuid())
  nombre       String
  tipo         String
  contenido    String             @default("")
  fechaInicio  DateTime?
  fechaFin     DateTime?
  fechaCorte   DateTime?
  createdAt    DateTime           @default(now())
  licitacionId String
  entidadId    Int?
  entidad      EntidadLicitacion? @relation("EntidadesDocumentos", fields: [entidadId], references: [id])
  licitacion   Licitacion         @relation(fields: [licitacionId], references: [id], onDelete: Cascade)

  @@unique([tipo, nombre, licitacionId])
}

model EntidadLicitacion {
  id            Int                   @id @default(autoincrement())
  key           String
  nombreOficial String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  documentos    LicitacionDocumento[] @relation("EntidadesDocumentos")
  licitaciones  Licitacion[]          @relation("EntidadesLicitaciones")
}

model LicitacionStatus {
  id            Int          @id @default(autoincrement())
  key           String
  nombreOficial String
  createdAt     DateTime     @default(now())
  licitaciones  Licitacion[]
}

model Proyecto {
  id           String   @id @default(cuid())
  codigo       String   @unique
  nombre       String
  cliente      String
  estado       String   @default("active")
  currentPhase String   @default("initiation") @map("current_phase")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([estado])
  @@index([currentPhase])
  @@map("proyectos")
}

model DocumentoChunk {
  id          String   @id @default(cuid())
  documentoId String
  contenido   String
  orden       Int
  embedding   Unsupported("vector(768)")
  createdAt   DateTime @default(now())

  documento DocumentoOficial @relation(fields: [documentoId], references: [id])

  @@index([documentoId])
  @@index([embedding])
}
