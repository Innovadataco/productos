DATABASE_URL="postgresql://proteccion:proteccion_dev@localhost:5433/proteccion_infantil"
JWT_SECRET="change-me-in-production-min-32-characters-long"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ENCRYPTION_KEY="change-me-in-production-32-chars!!"
EMAIL_FROM="no-reply@innovadataco.com"
WORKER_SECRET="change-me-in-production-at-least-32-chars"
NEXT_PUBLIC_APP_URL="http://localhost:5005"
# Emite headers CSP upgrade-insecure-requests y Strict-Transport-Security (HSTS).
# Solo habilitar cuando la app corra realmente bajo HTTPS (producción con TLS).
# En entornos locales o por HTTP (Tailscale, LAN) dejar en false para evitar bloqueo de estilos.
ENABLE_HTTPS_HEADERS=false

# Por defecto se detecta automaticamente segun el protocolo (HTTPS -> true, HTTP -> false).
# En redes locales por HTTP (ej: 192.168.x.x) usar: COOKIE_SECURE=false
COOKIE_SECURE=false
OLLAMA_BASE_URL="http://localhost:11434"
# Salt para hashes de señales de fuente (IP/fingerprint) en anti-abuso. Mínimo 32 caracteres.
ANTI_ABUSO_SALT="change-me-in-production-at-least-32-chars"
# Clave para cifrar valores de ParametroSistema con esSecreto=true. Debe tener exactamente 32 bytes (UTF-8) o 44 chars base64.
PARAM_ENCRYPTION_KEY="change-me-32-bytes-param-key-123"
# Proveedor de SMS para OTP de apelaciones. Solo "mock" implementado.
SMS_PROVIDER="mock"
# Email/contraseña del admin creado por el seed (obligatorio ADMIN_PASSWORD en producción).
ADMIN_EMAIL="admin@proteccion.local"
# ADMIN_PASSWORD="change-me-admin-password"
# URL que usa el worker para llamar a la API.
API_BASE_URL="http://localhost:5005"
# NEXT_PUBLIC_DISABLE_ONBOARDING=true
# dominio verificado en Resend
# Nivel mínimo de logs: debug | info | warn | error. En producción el default es warn.
LOG_LEVEL=info
