# =============================================================================
# Protección Infantil — Variables de entorno de PRODUCCIÓN (ejemplo)
# Copiar a .env.production y reemplazar TODOS los valores "change-me...".
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# URL de PostgreSQL con pgvector. Formato:
#   postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://proteccion:change-me@postgres:5432/proteccion_infantil"

# -----------------------------------------------------------------------------
# Autenticación / sesiones
# -----------------------------------------------------------------------------
# Secreto para firmar JWT. Generar con: openssl rand -base64 48
JWT_SECRET="change-me-with-openssl-rand-base64-48"

# Contraseña del usuario admin creado por el seed (solo si NODE_ENV=production).
# Obligatoria en producción. Generar con: openssl rand -base64 24
ADMIN_PASSWORD="change-me-admin-password"

# Email del usuario admin creado por el seed.
ADMIN_EMAIL="admin@proteccion.local"

# -----------------------------------------------------------------------------
# Worker / procesamiento
# -----------------------------------------------------------------------------
# Secreto compartido entre app y worker para /api/reportes/procesar.
# Generar con: openssl rand -base64 48
WORKER_SECRET="change-me-with-openssl-rand-base64-48"

# URL base pública de la app (usada por worker y enlaces de recuperación).
NEXT_PUBLIC_APP_URL="https://proteccion.ejemplo.com"

# URL que usa el worker para llamar a la API (normalmente igual a NEXT_PUBLIC_APP_URL).
API_BASE_URL="https://proteccion.ejemplo.com"

# -----------------------------------------------------------------------------
# Cookies / HTTPS
# -----------------------------------------------------------------------------
# true si la app se sirve por HTTPS (recomendado en producción).
COOKIE_SECURE="true"

# -----------------------------------------------------------------------------
# Ollama / IA
# -----------------------------------------------------------------------------
# URL base de Ollama. Debe ser localhost o IP privada (R2).
OLLAMA_BASE_URL="http://localhost:11434"

# Fallbacks de modelos si no existen los parámetros de sistema.
IA_MODEL_ANONIMIZACION="ornith:9b"
IA_MODEL_EMBEDDING="nomic-embed-text"
OLLAMA_NUM_PARALLEL="2"

# -----------------------------------------------------------------------------
# Anti-abuso
# -----------------------------------------------------------------------------
# Salt para hashes de IP/fingerprint. Generar con: openssl rand -base64 48
ANTI_ABUSO_SALT="change-me-with-openssl-rand-base64-48"

# -----------------------------------------------------------------------------
# Cifrado de parámetros secretos (T7)
# -----------------------------------------------------------------------------
# Clave de 32 bytes para AES-256-GCM de parámetros con esSecreto=true.
# Generar con: openssl rand -base64 32   (44 caracteres base64)
# o con: openssl rand -hex 32            (64 caracteres hex, también aceptado)
PARAM_ENCRYPTION_KEY="change-me-32-bytes-param-key-123"

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API key de Resend para envío de emails.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Remitente verificado en Resend.
EMAIL_FROM="no-reply@innovadataco.com"

# -----------------------------------------------------------------------------
# SMS (Apelaciones OTP)
# -----------------------------------------------------------------------------
# Proveedor de SMS. Valores: "mock" (desarrollo) o nombre de proveedor real.
# Por ahora solo existe "mock" implementado; elegir proveedor real es decisión de sesión.
SMS_PROVIDER="mock"

# -----------------------------------------------------------------------------
# Cifrado legacy (no usado por T7)
# -----------------------------------------------------------------------------
# Variable histórica; el código actual no la usa para parámetros. Mantener por compatibilidad.
ENCRYPTION_KEY="change-me-in-production-32-chars!!"

# -----------------------------------------------------------------------------
# Flags de entorno
# -----------------------------------------------------------------------------
# NODE_ENV=production se define en el runtime (systemd/pm2/docker).
# DISABLE_RATE_LIMIT=true solo para tests, nunca en producción.
# NEXT_PUBLIC_DISABLE_ONBOARDING=true para desactivar el tour inicial.
