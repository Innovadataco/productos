generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum RolUsuario {
  ADMIN
  SCHOOL_ADMIN
  PARENT
  OPERADOR
  COMITE_VALIDACION
}

enum EstadoUsuario {
  activo
  inactivo
  bloqueado
}

enum TipoParametro {
  STRING
  INTEGER
  FLOAT
  BOOLEAN
  JSON
  STRING_ARRAY
}

enum CategoriaParametro {
  VISIBILITY
  SECURITY
  LEGAL
  EMAIL
  SYSTEM
}

enum AccionAudit {
  LOGIN
  LOGOUT
  PARAM_UPDATE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  CODE_REQUEST
  CODE_VERIFY
  CODE_COMPLETE
  REPORT_DEACTIVATE
  REPORT_REACTIVATE
  EVAL_CASE_CREATE
  EVAL_CASE_DISABLE
  EVAL_RUN_CREATE
  EXPERIMENT_START
  EXPERIMENT_COMPLETE
  APELACION_CREADA
  APELACION_RESUELTA
  APELACION_VENCIDA
  APELACION_REHABILITADA
  CIRCULO_CONTACT_CREATE
  CIRCULO_CONTACT_UPDATE
  CIRCULO_CONTACT_DISABLE
  OPERADOR_CREADO
  OPERADOR_ACTIVADO
  OPERADOR_DESACTIVADO
  OPERADOR_ASIGNADO
  OPERADOR_REASIGNADO
  OPERADOR_PASSWORD_REGENERADA
  OPERADOR_EMAIL_REENVIADO
  COMITE_CREADO
  COMITE_ACTIVADO
  COMITE_DESACTIVADO
  COMITE_PASSWORD_REGENERADA
  COMITE_EMAIL_REENVIADO
  COMITE_INTEGRANTE_CREADO
  COMITE_INTEGRANTE_ACTUALIZADO
  COMITE_INTEGRANTE_INACTIVADO
  CASO_CONFIRMADO
  CASO_CORREGIDO
  CASO_DADO_DE_BAJA
  CASO_ESCALADO
  CASO_RESUELTO_POR_COMITE
  CASO_REASIGNADO
  CASO_NOTA_AGREGADA
  CONFIGURACION_ASIGNACION_ACTUALIZADA
  TEXTO_ORIGINAL_REVELADO
  ANONIMIZACION_VALIDADA
  ANONIMIZACION_RECHAZADA
  COLEGIO_CREADO
  PERMISOS_MODULO_ACTUALIZADOS
  COLEGIO_ACTUALIZADO
  COLEGIO_DESACTIVADO
  COLEGIO_REACTIVADO
  COLEGIO_PASSWORD_REGENERADA
  COLEGIO_EMAIL_REENVIADO
  COLEGIO_CURSO_CREADO
  COLEGIO_CURSO_EDITADO
  COLEGIO_CURSO_DESACTIVADO
  COLEGIO_ALUMNO_CREADO
  COLEGIO_ALUMNO_EDITADO
  COLEGIO_ALUMNO_DESACTIVADO
  COLEGIO_IDENTIFICADOR_CREADO
  COLEGIO_IDENTIFICADOR_EDITADO
  COLEGIO_IDENTIFICADOR_DESACTIVADO
  COLEGIO_CARGA_MASIVA
  COLEGIO_ALERTA_CREADA
  COLEGIO_ALERTA_ESTADO
  COLEGIO_ESTADISTICAS_PDF_DESCARGADO
}

enum TipoPeriodoServicio {
  MENSUAL
  SEMESTRAL
  ANUAL
}

enum EstadoApelacion {
  RECIBIDA
  EN_REVISION
  ACEPTADA
  RECHAZADA
  VENCIDA
}

enum EtiquetaRelacionAlumno {
  ALUMNO
  MADRE
  PADRE
  PRIMO
  TUTOR
  OTRO
}

enum TipoIdentificacionIntegrante {
  CEDULA_CIUDADANIA
  CEDULA_EXTRANJERIA
  PASAPORTE
  OTRO
}

enum EstadoIntegranteComite {
  ACTIVO
  INACTIVO
}

enum MotivoBajaReporte {
  RETIRO_LIMPIEZA
  REPORTE_FALSO
  ORDEN_LEGAL
}

enum CategoriaConducta {
  CONTACTO_INSISTENTE
  SOLICITUD_MATERIAL
  OFRECIMIENTO_REGALOS
  SUPLANTACION_IDENTIDAD
  SOLICITUD_ENCUENTRO
  COMPARTIMIENTO_SEXUAL
  OTRO
  EXTORSION
  CONTENIDO_GENERADO_IA
  DIFUSION_NO_CONSENTIDA
  DOXING
  SPAM
}

enum EstadoReporte {
  PENDIENTE
  PROCESANDO
  CLASIFICADO
  REVISION_MANUAL
  POSIBLE_SPAM
  DUPLICADO
  REQUIERE_ANONIMIZACION
  CORREGIDO
}

enum ResponsableTransicion {
  IA
  WORKER
  SISTEMA
  OPERADOR
  COMITE
  ADMIN
}

model Usuario {
  id                  String        @id @default(cuid())
  email               String        @unique
  nombre              String?
  passwordHash        String
  rol                 RolUsuario
  estado              EstadoUsuario @default(activo)
  debeCambiarPassword Boolean       @default(false)
  intentosFallidos    Int           @default(0)
  bloqueadoHasta      DateTime?
  ultimaSesion        DateTime?
  tenantId            String?
  colegioId           String?       @unique
  creadoEn            DateTime      @default(now())
  actualizadoEn       DateTime      @updatedAt

  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  colegio                      Colegio?                 @relation(fields: [colegioId], references: [id])
  parametros                   ParametroSistema[]
  auditLogs                    AuditLog[]
  permisosModuloActualizados   PermisoModulo[]
  codigos                      CodigoVerificacion[]
  tokensRecuperacion           TokenRecuperacion[]
  reportes                     Reporte[]
  reportesDadosDeBaja          Reporte[]                @relation("ReportesDadosDeBaja")
  correcciones                 CorreccionAdmin[]
  alertasSuscripcion           AlertaSuscripcion[]
  casosEval                    CasoEval[]
  evalRuns                     EvalRun[]
  simulaciones                 SimulacionRun[]
  apelaciones                  ApelacionIdentificador[]
  casosAsignados               Reporte[]                @relation("CasosOperador")
  casosComiteAsignados         Reporte[]                @relation("CasosComite")
  apelacionesAsignadas         ApelacionIdentificador[] @relation("ApelacionesOperador")
  anonimizacionesValidadas     Reporte[]                @relation("AnonimizacionesValidadas")
  perfilOperador               PerfilOperador?
  operadoresCreados            PerfilOperador[]         @relation("OperadoresCreados")
  contactosConfianza           ContactoConfianza[]
  notificacionesCirculo        Boolean                  @default(true)
  ultimaNotificacionCirculoEn    DateTime?
  ultimaNotificacionColegioEn    DateTime?
  transicionesReporte          TransicionReporte[]
  solicitudesComite            SolicitudComite[]        @relation("SolicitudesComite")
  solicitudesEscaladas         SolicitudComite[]        @relation("SolicitudesEscaladas")
  integrantesComite            IntegranteComite[]       @relation("IntegrantesComite")
  integrantesComiteCreados     IntegranteComite[]       @relation("IntegrantesComiteCreados")
  integrantesComiteModificados IntegranteComite[]       @relation("IntegrantesComiteModificados")

  @@index([email])
  @@index([rol])
  @@index([estado])
  @@index([tenantId])
}

model PerfilOperador {
  id                        String    @id @default(cuid())
  usuarioId                 String    @unique
  cupoMaximo                Int?
  esRevisorDeApelaciones    Boolean   @default(false)
  esComite                  Boolean   @default(false)
  notasInternas             String?
  ultimoEmailNotificacionEn DateTime?
  creadoPorId               String
  creadoEn                  DateTime  @default(now())
  actualizadoEn             DateTime  @updatedAt

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorId], references: [id], name: "OperadoresCreados")

  @@index([usuarioId])
  @@index([creadoPorId])
  @@index([esComite])
}

model IntegranteComite {
  id                   String                       @id @default(cuid())
  comiteId             String
  nombres              String
  apellidos            String
  tipoIdentificacion   TipoIdentificacionIntegrante
  numeroIdentificacion String
  email                String
  fechaInicio          DateTime                     @default(now())
  fechaFin             DateTime?
  estado               EstadoIntegranteComite       @default(ACTIVO)
  creadoPorId          String
  modificadoPorId      String?
  creadoEn             DateTime                     @default(now())
  actualizadoEn        DateTime                     @updatedAt

  comite        Usuario  @relation(fields: [comiteId], references: [id], name: "IntegrantesComite", onDelete: Cascade)
  creadoPor     Usuario  @relation(fields: [creadoPorId], references: [id], name: "IntegrantesComiteCreados")
  modificadoPor Usuario? @relation(fields: [modificadoPorId], references: [id], name: "IntegrantesComiteModificados")

  @@index([comiteId])
  @@index([estado])
  @@index([tipoIdentificacion])
}

model CodigoVerificacion {
  id               String   @id @default(cuid())
  email            String
  codigoHash       String
  expiraEn         DateTime
  intentosFallidos Int      @default(0)
  usado            Boolean  @default(false)
  creadoEn         DateTime @default(now())

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([email])
  @@index([creadoEn])
}

model TokenRecuperacion {
  id            String   @id @default(cuid())
  email         String
  tokenHash     String
  expiraEn      DateTime
  usado         Boolean  @default(false)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([email])
  @@index([tokenHash])
  @@index([expiraEn])
}

model ParametroSistema {
  id               String             @id @default(cuid())
  clave            String             @unique
  valor            String
  tipo             TipoParametro
  categoria        CategoriaParametro
  esPublico        Boolean            @default(false)
  esSecreto        Boolean            @default(false)
  descripcion      String?
  reglasValidacion String?
  creadoEn         DateTime           @default(now())
  actualizadoEn    DateTime           @updatedAt
  actualizadoPorId String?

  actualizadoPor Usuario?   @relation(fields: [actualizadoPorId], references: [id])
  auditLogs      AuditLog[]

  @@index([clave])
  @@index([categoria])
}

model AuditLog {
  id            String      @id @default(cuid())
  accion        AccionAudit
  tipoRecurso   String
  recursoId     String?
  usuarioId     String?
  parametroId   String?
  colegioId     String?
  valorAnterior String?
  valorNuevo    String?
  ipAddress     String
  userAgent     String
  metadatos     Json?
  creadoEn      DateTime    @default(now())

  usuario   Usuario?          @relation(fields: [usuarioId], references: [id])
  parametro ParametroSistema? @relation(fields: [parametroId], references: [id])
  colegio   Colegio?          @relation(fields: [colegioId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([parametroId])
  @@index([colegioId])
  @@index([accion])
  @@index([creadoEn])
}

model Tenant {
  id       String   @id @default(cuid())
  nombre   String
  estado   String   @default("activo")
  creadoEn DateTime @default(now())

  usuarios Usuario[]
  reportes Reporte[]
  colegio  Colegio?
}

model Plan {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  precio      Float
  creadoEn    DateTime @default(now())
}

model Subscription {
  id        String    @id @default(cuid())
  tenantId  String
  planId    String
  estado    String    @default("activo")
  iniciaEn  DateTime
  terminaEn DateTime?
  creadoEn  DateTime  @default(now())
}

model BillingCycle {
  id             String   @id @default(cuid())
  subscriptionId String
  monto          Float
  estado         String   @default("pendiente")
  periodoInicio  DateTime
  periodoFin     DateTime
  creadoEn       DateTime @default(now())
}

model Colegio {
  id                               String              @id @default(cuid())
  nombre                           String
  paisId                           String
  departamentoId                   String?
  ciudadId                         String
  direccion                        String?
  representanteLegalNombre         String
  representanteLegalIdentificacion String
  representanteLegalEmail          String
  representanteLegalTelefono       String?
  inicioServicio                   DateTime
  finServicio                      DateTime?
  tipoPeriodo                      TipoPeriodoServicio
  estado                           String              @default("activo")
  tenantId                         String              @unique
  creadoEn                         DateTime            @default(now())
  actualizadoEn                    DateTime            @updatedAt

  pais         Pais          @relation(fields: [paisId], references: [id])
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
  ciudad       Ciudad        @relation(fields: [ciudadId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  admin        Usuario?
  cursos       Curso[]
  alumnos      Alumno[]
  alertas      AlertaColegio[]
  auditLogs    AuditLog[]

  @@index([paisId])
  @@index([departamentoId])
  @@index([ciudadId])
  @@index([estado])
}

model Curso {
  id          String   @id @default(cuid())
  colegioId   String
  nombre      String
  grado       String?
  anioLectivo String?
  estado      String   @default("activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  colegio Colegio  @relation(fields: [colegioId], references: [id])
  alumnos Alumno[]

  @@index([colegioId, estado])
  @@unique([colegioId, nombre, grado, anioLectivo])
}

model Alumno {
  id        String   @id @default(cuid())
  cursoId   String
  colegioId String
  nombre    String
  estado    String   @default("activo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curso           Curso               @relation(fields: [cursoId], references: [id])
  colegio         Colegio             @relation(fields: [colegioId], references: [id])
  identificadores IdentificadorAlumno[]

  @@index([cursoId, estado])
  @@index([colegioId, estado])
}

model IdentificadorAlumno {
  id               String                  @id @default(cuid())
  alumnoId         String
  tipo             String
  valor            String
  plataformaId     String?
  etiquetaRelacion EtiquetaRelacionAlumno @default(ALUMNO)
  estado           String                  @default("activo")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  alumno     Alumno      @relation(fields: [alumnoId], references: [id])
  plataforma Plataforma? @relation(fields: [plataformaId], references: [id])
  alertas    AlertaColegio[]

  @@unique([alumnoId, valor, tipo, plataformaId])
  @@index([alumnoId, estado])
}

model AlertaColegio {
  id                    String   @id @default(cuid())
  colegioId             String
  reporteId             String
  identificadorAlumnoId String
  estado                String   @default("nueva") // nueva | vista | gestionada
  creadoEn              DateTime @default(now())
  actualizadoEn         DateTime @updatedAt

  colegio             Colegio            @relation(fields: [colegioId], references: [id])
  reporte             Reporte            @relation(fields: [reporteId], references: [id])
  identificadorAlumno IdentificadorAlumno @relation(fields: [identificadorAlumnoId], references: [id])

  @@unique([colegioId, reporteId, identificadorAlumnoId])
  @@index([colegioId, estado])
  @@index([reporteId])
}

// ============================================
// MÓDULO DE REPORTES COMUNITARIOS (FASE 2)
// ============================================

model Plataforma {
  id        String   @id @default(cuid())
  clave     String   @unique
  nombre    String
  categoria String   @default("otro")
  esActiva  Boolean  @default(true)
  creadoEn  DateTime @default(now())

  reportes                Reporte[]
  identificadores         IdentificadorReportado[]
  alertasSuscripcion      AlertaSuscripcion[]
  apelaciones             ApelacionIdentificador[]
  identificadoresContacto IdentificadorContacto[]
  identificadoresAlumno IdentificadorAlumno[]

  @@index([clave])
  @@index([esActiva])
}

model Pais {
  id       String   @id @default(cuid())
  codigo   String   @unique
  nombre   String
  esActivo Boolean  @default(true)
  creadoEn DateTime @default(now())

  ciudades      Ciudad[]
  departamentos Departamento[]
  colegios      Colegio[]
  reportes      Reporte[]

  @@index([codigo])
  @@index([esActivo])
}

model Departamento {
  id            String   @id @default(cuid())
  codigo        String?  @unique
  nombre        String
  paisId        String
  esActivo      Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  pais     Pais      @relation(fields: [paisId], references: [id])
  ciudades Ciudad[]
  colegios Colegio[]

  @@unique([nombre, paisId])
  @@index([paisId])
  @@index([esActivo])
}

model Ciudad {
  id             String   @id @default(cuid())
  nombre         String
  paisId         String
  departamentoId String?
  lat            Float?
  lng            Float?
  esActivo       Boolean  @default(true)
  creadoEn       DateTime @default(now())

  pais         Pais          @relation(fields: [paisId], references: [id])
  departamento Departamento? @relation(fields: [departamentoId], references: [id])
  colegios     Colegio[]
  reportes     Reporte[]

  @@unique([nombre, paisId])
  @@index([paisId])
  @@index([departamentoId])
  @@index([esActivo])
}

model Reporte {
  id                         String             @id @default(cuid())
  identificador              String
  plataformaId               String
  texto                      String             @db.Text
  textoOriginal              String?            @db.Text
  fechaIncidente             DateTime
  ciudad                     String
  pais                       String
  paisId                     String?
  ciudadId                   String?
  otraPlataforma             String?
  estado                     EstadoReporte      @default(PENDIENTE)
  esAnonimo                  Boolean            @default(true)
  edadVictima                Int?
  usuarioId                  String?
  operadorId                 String?
  comiteId                   String?
  reporteOrigenId            String?
  numeroSeguimiento          String?            @unique
  tenantId                   String?
  processingError            String?            @db.Text
  prioridadAlta              Boolean            @default(false)
  keywordsDetectadas         String[]
  esRafaga                   Boolean            @default(false)
  fuenteConfianza            Float?
  eliminado                  Boolean            @default(false)
  motivoBaja                 MotivoBajaReporte?
  notaBaja                   String?            @db.Text
  eliminadoEn                DateTime?
  eliminadoPorId             String?
  anonimizacionValidadaPorId String?
  anonimizacionValidadaEn    DateTime?
  creadoEn                   DateTime           @default(now())
  actualizadoEn              DateTime           @updatedAt

  plataforma               Plataforma          @relation(fields: [plataformaId], references: [id])
  usuario                  Usuario?            @relation(fields: [usuarioId], references: [id])
  eliminadoPor             Usuario?            @relation(fields: [eliminadoPorId], references: [id], name: "ReportesDadosDeBaja")
  operador                 Usuario?            @relation(fields: [operadorId], references: [id], name: "CasosOperador")
  comite                   Usuario?            @relation(fields: [comiteId], references: [id], name: "CasosComite")
  anonimizacionValidadaPor Usuario?            @relation(fields: [anonimizacionValidadaPorId], references: [id], name: "AnonimizacionesValidadas")
  reporteOrigen            Reporte?            @relation("ReporteDuplicado", fields: [reporteOrigenId], references: [id])
  duplicados               Reporte[]           @relation("ReporteDuplicado")
  clasificacion            ClasificacionIA?
  embedding                EmbeddingReporte?
  fuente                   FuenteReporte?
  tenant                   Tenant?             @relation(fields: [tenantId], references: [id])
  paisRel                  Pais?               @relation(fields: [paisId], references: [id])
  ciudadRel                Ciudad?             @relation(fields: [ciudadId], references: [id])
  transiciones             TransicionReporte[]
  reintentos               ReintentoReporte[]
  solicitudComite          SolicitudComite?
  alertasColegio           AlertaColegio[]

  @@index([identificador, plataformaId])
  @@index([estado])
  @@index([usuarioId, identificador])
  @@index([creadoEn])
  @@index([numeroSeguimiento])
  @@index([paisId])
  @@index([ciudadId])
  @@index([eliminado])
  @@index([eliminadoPorId])
  @@index([operadorId])
  @@index([comiteId])
  @@index([anonimizacionValidadaPorId])
}

model SolicitudComite {
  id         String    @id @default(cuid())
  reporteId  String    @unique
  numero     String    @unique
  estado     String    @default("PENDIENTE")
  comiteId   String?
  operadorId String?
  motivo     String    @db.Text
  resolucion String?   @db.Text
  creadoEn   DateTime  @default(now())
  resueltoEn DateTime?

  reporte  Reporte  @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  comite   Usuario? @relation(fields: [comiteId], references: [id], name: "SolicitudesComite")
  operador Usuario? @relation(fields: [operadorId], references: [id], name: "SolicitudesEscaladas")

  @@index([estado])
  @@index([comiteId])
  @@index([operadorId])
  @@index([creadoEn])
}

model TransicionReporte {
  id              String                @id @default(cuid())
  reporteId       String
  estadoAnterior  EstadoReporte
  estadoNuevo     EstadoReporte
  responsableTipo ResponsableTransicion
  responsableId   String?
  motivo          String?               @db.Text
  metadatos       Json?
  creadoEn        DateTime              @default(now())

  reporte            Reporte  @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  responsableUsuario Usuario? @relation(fields: [responsableId], references: [id], onDelete: SetNull)

  @@index([reporteId])
  @@index([responsableTipo])
  @@index([responsableId])
  @@index([creadoEn])
}

model ReintentoReporte {
  id        String   @id @default(cuid())
  reporteId String
  intento   Int
  exitoso   Boolean  @default(false)
  error     String?  @db.Text
  creadoEn  DateTime @default(now())

  reporte Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  @@index([reporteId])
  @@index([creadoEn])
}

model FuenteReporte {
  id                   String   @id @default(cuid())
  reporteId            String   @unique
  ipHash               String?
  fingerprintHash      String?
  cuentaDiasAntiguedad Int?
  reportesPrevios      Int      @default(0)
  reportesConfirmados  Int      @default(0)
  reportesDescartados  Int      @default(0)
  pesoAplicado         Float
  creadoEn             DateTime @default(now())

  reporte Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  @@index([ipHash])
  @@index([fingerprintHash])
  @@index([creadoEn])
}

model IdentificadorReportado {
  id                    String    @id @default(cuid())
  identificador         String
  plataformaId          String
  totalReportes         Int       @default(0)
  reportesAutenticados  Int       @default(0)
  reportesAnonimos      Int       @default(0)
  esVisiblePublicamente Boolean   @default(false)
  score                 Int       @default(0)
  scoreAnonimo          Int       @default(0)
  scoreAutenticado      Int       @default(0)
  scoreAjustado         Int       @default(0)
  nivelRiesgo           String?
  ultimoReporteEn       DateTime?
  creadoEn              DateTime  @default(now())
  actualizadoEn         DateTime  @updatedAt

  plataforma  Plataforma               @relation(fields: [plataformaId], references: [id])
  apelaciones ApelacionIdentificador[]

  @@unique([identificador, plataformaId])
  @@index([esVisiblePublicamente])
  @@index([totalReportes])
  @@index([score])
}

model ApelacionIdentificador {
  id                    String          @id @default(cuid())
  identificador         String
  plataformaId          String
  tokenAcceso           String          @unique
  estado                EstadoApelacion @default(RECIBIDA)
  motivoSolicitud       String
  evidenciaUrl          String?
  respuestaAdmin        String?
  adminId               String?
  operadorId            String?
  tipoVerificacion      String // SMS | NICK
  contacto              String?
  smsCodigoHash         String?
  smsVerificado         Boolean         @default(false)
  smsIntentos           Int             @default(0)
  pausaHasta            DateTime?
  visibilidadRestaurada Boolean         @default(false)
  derechoApelar         Boolean         @default(true)
  notaRehabilitacion    String?
  creadoEn              DateTime        @default(now())
  actualizadoEn         DateTime        @updatedAt

  plataforma             Plataforma             @relation(fields: [plataformaId], references: [id])
  admin                  Usuario?               @relation(fields: [adminId], references: [id])
  operador               Usuario?               @relation(fields: [operadorId], references: [id], name: "ApelacionesOperador")
  identificadorReportado IdentificadorReportado @relation(fields: [identificador, plataformaId], references: [identificador, plataformaId])

  @@index([identificador, plataformaId])
  @@index([estado])
  @@index([tokenAcceso])
  @@index([operadorId])
}

model ContactoConfianza {
  id            String   @id @default(cuid())
  usuarioId     String
  etiqueta      String?  @db.VarChar(100)
  nota          String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario         Usuario                 @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  identificadores IdentificadorContacto[]

  @@index([usuarioId, activo])
  @@index([usuarioId, creadoEn])
}

model IdentificadorContacto {
  id            String   @id @default(cuid())
  contactoId    String
  valor         String
  tipo          String?
  plataformaId  String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  contacto   ContactoConfianza @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  plataforma Plataforma?       @relation(fields: [plataformaId], references: [id])

  @@unique([contactoId, valor, plataformaId])
  @@index([valor])
  @@index([contactoId, activo])
  @@index([plataformaId])
}

model AlertaSuscripcion {
  id            String    @id @default(cuid())
  usuarioId     String
  identificador String
  plataformaId  String
  activa        Boolean   @default(true)
  ultimoEmailEn DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  plataforma Plataforma @relation(fields: [plataformaId], references: [id])

  @@unique([usuarioId, identificador, plataformaId])
  @@index([usuarioId])
  @@index([identificador, plataformaId])
  @@index([activa])
}

model ClasificacionIA {
  id                    String            @id @default(cuid())
  reporteId             String            @unique
  categoria             CategoriaConducta
  confianza             Float
  contienePii           Boolean           @default(false)
  piiDetectada          String[]
  modeloUsado           String
  latenciaMs            Int
  promptTokens          Int?
  responseTokens        Int?
  rawResponse           String?           @db.Text
  categoriasSecundarias Json?
  votos                 Json?
  usoCascada            Boolean           @default(false)
  modeloCascada         String?
  posibleAgresorPar     Boolean           @default(false)
  creadoEn              DateTime          @default(now())

  reporte    Reporte          @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  correccion CorreccionAdmin?

  @@index([categoria])
  @@index([confianza])
}

model CorreccionAdmin {
  id                 String            @id @default(cuid())
  clasificacionId    String            @unique
  categoriaOriginal  CategoriaConducta
  categoriaCorregida CategoriaConducta
  adminId            String
  motivo             String?           @db.Text
  confirmada         Boolean           @default(false)
  creadoEn           DateTime          @default(now())

  clasificacion    ClasificacionIA        @relation(fields: [clasificacionId], references: [id], onDelete: Cascade)
  admin            Usuario                @relation(fields: [adminId], references: [id])
  datasetRegistros DatasetEntrenamiento[]

  @@index([adminId])
}

model DatasetEntrenamiento {
  id                     String            @id @default(cuid())
  texto                  String            @db.Text
  clasificacionCorrecta  CategoriaConducta
  fuente                 String
  correccionId           String?
  usadoParaEntrenamiento Boolean           @default(false)
  textoAnonimizado       Boolean           @default(false)
  creadoEn               DateTime          @default(now())

  correccion CorreccionAdmin?  @relation(fields: [correccionId], references: [id])
  embedding  EmbeddingDataset?

  @@index([usadoParaEntrenamiento])
}

model EmbeddingDataset {
  id          String                     @id @default(cuid())
  datasetId   String                     @unique
  // Índice hnsw sobre vector creado por migración SQL manual (20260717002004_add_pgvector_hnsw_indexes).
  // Prisma no lo gestiona; verificar que exista tras cada migrate deploy.
  vector      Unsupported("vector(768)")
  modeloUsado String
  creadoEn    DateTime                   @default(now())

  dataset DatasetEntrenamiento @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model EmbeddingReporte {
  id          String                     @id @default(cuid())
  reporteId   String                     @unique
  // Índice hnsw sobre vector creado por migración SQL manual (20260717002004_add_pgvector_hnsw_indexes).
  // Prisma no lo gestiona; verificar que exista tras cada migrate deploy.
  vector      Unsupported("vector(768)")
  modeloUsado String
  creadoEn    DateTime                   @default(now())

  reporte Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)
}

model RateLimit {
  key           String   @id
  scope         String
  identifier    String
  windowStart   DateTime
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([scope, identifier, windowStart])
}

enum CasoEvalFuente {
  SEMILLA
  MANUAL_ADMIN
  PRODUCCION_ANONIMIZADO
}

model CasoEval {
  id                 String         @id @default(cuid())
  texto              String         @db.Text
  categoriaEsperada  String
  secundariaEsperada String?
  ruido              Boolean        @default(false)
  fuente             CasoEvalFuente @default(SEMILLA)
  activo             Boolean        @default(true)
  fixtureVersion     Int            @default(1)
  creadoPorId        String?
  creadoEn           DateTime       @default(now())

  creadoPor  Usuario?        @relation(fields: [creadoPorId], references: [id])
  resultados EvalResultado[]

  @@index([categoriaEsperada])
  @@index([fuente])
  @@index([activo])
  @@index([fixtureVersion])
}

enum EvalRunEstado {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  FALLIDA
  CANCELADA
}

model EvalRun {
  id             String        @id @default(cuid())
  tipo           String        @default("f7")
  fixtureVersion Int
  estado         EvalRunEstado @default(PENDIENTE)
  iniciadoEn     DateTime      @default(now())
  finalizadoEn   DateTime?
  resultadoJson  Json?
  error          String?       @db.Text
  creadoPorId    String?

  // Spec 014 — Laboratorio de experimentos
  nombre         String?
  notas          String? @db.Text
  configSnapshot Json?
  progresoCasos  Int     @default(0)
  progresoTotal  Int     @default(0)

  creadoPor  Usuario?        @relation(fields: [creadoPorId], references: [id])
  resultados EvalResultado[]

  @@index([estado])
  @@index([fixtureVersion])
  @@index([creadoPorId])
}

model EvalResultado {
  id            String   @id @default(cuid())
  experimentoId String
  casoEvalId    String
  esperado      String
  predicho      String
  confianza     Float
  estadoFinal   String
  correcto      Boolean
  latenciaMs    Int
  creadoEn      DateTime @default(now())

  experimento EvalRun  @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  casoEval    CasoEval @relation(fields: [casoEvalId], references: [id], onDelete: Cascade)

  @@index([experimentoId])
  @@index([casoEvalId])
  @@index([correcto])
  @@index([esperado])
}

model SimulacionRun {
  id           String              @id @default(cuid())
  modelo       String
  totalCasos   Int                 @default(0)
  progreso     Int                 @default(0)
  estado       String              @default("PENDIENTE") // PENDIENTE | EN_PROGRESO | COMPLETADA | FALLIDA | CANCELADA
  fechaInicio  DateTime            @default(now())
  fechaFin     DateTime?
  metricasJson Json?
  casosJson    Json? // Set de casos cargado (persistido para reejecución / comparación)
  creadoPorId  String
  creadoPor    Usuario             @relation(fields: [creadoPorId], references: [id])
  casos        SimulacionReporte[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([estado])
  @@index([creadoPorId])
  @@map("simulacion_runs")
}

model SimulacionReporte {
  id                String        @id @default(cuid())
  simulacionRunId   String
  simulacionRun     SimulacionRun @relation(fields: [simulacionRunId], references: [id], onDelete: Cascade)
  reporteId         String        @unique
  indice            Int
  categoriaEsperada String?
  secundariaEsperada String?
  createdAt         DateTime      @default(now())

  @@index([simulacionRunId])
  @@index([indice])
  @@index([reporteId])
  @@map("simulacion_reportes")
}

model ModuloPermisible {
  id            String   @id @default(cuid())
  clave         String   @unique
  nombre        String
  descripcion   String?
  padreId       String?
  categoria     String
  esCritico     Boolean  @default(false)
  orden         Int      @default(0)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  padre      ModuloPermisible?  @relation("JerarquiaModulos", fields: [padreId], references: [id], onDelete: Restrict)
  submodulos ModuloPermisible[] @relation("JerarquiaModulos")
  permisos   PermisoModulo[]

  @@index([padreId])
}

model PermisoModulo {
  id               String   @id @default(cuid())
  rol              String
  moduloId         String
  activo           Boolean  @default(false)
  actualizadoPorId String?
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  modulo         ModuloPermisible @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  actualizadoPor Usuario?         @relation(fields: [actualizadoPorId], references: [id])

  @@unique([rol, moduloId])
  @@index([rol])
}
