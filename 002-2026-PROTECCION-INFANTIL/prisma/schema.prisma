generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum RolUsuario {
  ADMIN
  SCHOOL_ADMIN
  PARENT
  OPERADOR
}

enum EstadoUsuario {
  activo
  inactivo
  bloqueado
}

enum TipoParametro {
  STRING
  INTEGER
  FLOAT
  BOOLEAN
  JSON
  STRING_ARRAY
}

enum CategoriaParametro {
  VISIBILITY
  SECURITY
  LEGAL
  EMAIL
  SYSTEM
}

enum AccionAudit {
  LOGIN
  LOGOUT
  PARAM_UPDATE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  CODE_REQUEST
  CODE_VERIFY
  CODE_COMPLETE
  REPORT_DEACTIVATE
  REPORT_REACTIVATE
  EVAL_CASE_CREATE
  EVAL_CASE_DISABLE
  EVAL_RUN_CREATE
  EXPERIMENT_START
  EXPERIMENT_COMPLETE
  APELACION_CREADA
  APELACION_RESUELTA
  APELACION_VENCIDA
  APELACION_REHABILITADA
  CIRCULO_CONTACT_CREATE
  CIRCULO_CONTACT_UPDATE
  CIRCULO_CONTACT_DISABLE
  OPERADOR_CREADO
  OPERADOR_ACTIVADO
  OPERADOR_DESACTIVADO
  OPERADOR_ASIGNADO
  OPERADOR_REASIGNADO
  OPERADOR_PASSWORD_REGENERADA
  OPERADOR_EMAIL_REENVIADO
  CASO_CONFIRMADO
  CASO_CORREGIDO
  CASO_DADO_DE_BAJA
  CASO_ESCALADO
  CASO_NOTA_AGREGADA
  CONFIGURACION_ASIGNACION_ACTUALIZADA
}

enum EstadoApelacion {
  RECIBIDA
  EN_REVISION
  ACEPTADA
  RECHAZADA
  VENCIDA
}

enum MotivoBajaReporte {
  RETIRO_LIMPIEZA
  REPORTE_FALSO
  ORDEN_LEGAL
}

enum CategoriaConducta {
  CONTACTO_INSISTENTE
  SOLICITUD_MATERIAL
  OFRECIMIENTO_REGALOS
  SUPLANTACION_IDENTIDAD
  SOLICITUD_ENCUENTRO
  COMPARTIMIENTO_SEXUAL
  OTRO
  EXTORSION
  CONTENIDO_GENERADO_IA
  DIFUSION_NO_CONSENTIDA
  DOXING
}

enum EstadoReporte {
  PENDIENTE
  PROCESANDO
  CLASIFICADO
  REVISION_MANUAL
  POSIBLE_SPAM
  DUPLICADO
  REQUIERE_ANONIMIZACION
  CORREGIDO
}

enum ResponsableTransicion {
  IA
  WORKER
  SISTEMA
  OPERADOR
  COMITE
  ADMIN
}

model Usuario {
  id               String        @id @default(cuid())
  email            String        @unique
  nombre           String?
  passwordHash     String
  rol                  RolUsuario
  estado               EstadoUsuario @default(activo)
  debeCambiarPassword  Boolean       @default(false)
  intentosFallidos     Int           @default(0)
  bloqueadoHasta       DateTime?
  ultimaSesion         DateTime?
  tenantId             String?
  creadoEn             DateTime      @default(now())
  actualizadoEn        DateTime      @updatedAt

  tenant              Tenant?                  @relation(fields: [tenantId], references: [id])
  parametros          ParametroSistema[]
  auditLogs           AuditLog[]
  codigos             CodigoVerificacion[]
  tokensRecuperacion  TokenRecuperacion[]
  reportes              Reporte[]
  reportesDadosDeBaja   Reporte[]                @relation("ReportesDadosDeBaja")
  correcciones          CorreccionAdmin[]
  alertasSuscripcion    AlertaSuscripcion[]
  casosEval             CasoEval[]
  evalRuns              EvalRun[]
  apelaciones           ApelacionIdentificador[]
  casosAsignados        Reporte[]                @relation("CasosOperador")
  apelacionesAsignadas  ApelacionIdentificador[] @relation("ApelacionesOperador")
  perfilOperador        PerfilOperador?
  operadoresCreados     PerfilOperador[]         @relation("OperadoresCreados")
  contactosConfianza            ContactoConfianza[]
  notificacionesCirculo         Boolean                  @default(true)
  ultimaNotificacionCirculoEn   DateTime?
  transicionesReporte           TransicionReporte[]

  @@index([email])
  @@index([rol])
  @@index([estado])
  @@index([tenantId])
}

model PerfilOperador {
  id                       String   @id @default(cuid())
  usuarioId                String   @unique
  cupoMaximo               Int?
  esRevisorDeApelaciones Boolean  @default(false)
  notasInternas            String?
  creadoPorId              String
  creadoEn                 DateTime @default(now())
  actualizadoEn            DateTime @updatedAt

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  creadoPor Usuario @relation(fields: [creadoPorId], references: [id], name: "OperadoresCreados")

  @@index([usuarioId])
  @@index([creadoPorId])
}

model CodigoVerificacion {
  id               String   @id @default(cuid())
  email            String
  codigoHash       String
  expiraEn         DateTime
  intentosFallidos Int      @default(0)
  usado            Boolean  @default(false)
  creadoEn         DateTime @default(now())

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([email])
  @@index([creadoEn])
}

model TokenRecuperacion {
  id            String   @id @default(cuid())
  email         String
  tokenHash     String
  expiraEn      DateTime
  usado         Boolean  @default(false)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([email])
  @@index([tokenHash])
  @@index([expiraEn])
}

model ParametroSistema {
  id               String             @id @default(cuid())
  clave            String             @unique
  valor            String
  tipo             TipoParametro
  categoria        CategoriaParametro
  esPublico        Boolean            @default(false)
  esSecreto        Boolean            @default(false)
  descripcion      String?
  reglasValidacion String?
  creadoEn         DateTime           @default(now())
  actualizadoEn    DateTime           @updatedAt
  actualizadoPorId String?

  actualizadoPor Usuario?   @relation(fields: [actualizadoPorId], references: [id])
  auditLogs      AuditLog[]

  @@index([clave])
  @@index([categoria])
}

model AuditLog {
  id            String      @id @default(cuid())
  accion        AccionAudit
  tipoRecurso   String
  recursoId     String?
  usuarioId     String?
  parametroId   String?
  valorAnterior String?
  valorNuevo    String?
  ipAddress     String
  userAgent     String
  metadatos     Json?
  creadoEn      DateTime    @default(now())

  usuario   Usuario?          @relation(fields: [usuarioId], references: [id])
  parametro ParametroSistema? @relation(fields: [parametroId], references: [id])

  @@index([usuarioId])
  @@index([parametroId])
  @@index([accion])
  @@index([creadoEn])
}

model Tenant {
  id       String   @id @default(cuid())
  nombre   String
  estado   String   @default("activo")
  creadoEn DateTime @default(now())

  usuarios Usuario[]
  reportes Reporte[]
}

model Plan {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  precio      Float
  creadoEn    DateTime @default(now())
}

model Subscription {
  id        String    @id @default(cuid())
  tenantId  String
  planId    String
  estado    String    @default("activo")
  iniciaEn  DateTime
  terminaEn DateTime?
  creadoEn  DateTime  @default(now())
}

model BillingCycle {
  id             String   @id @default(cuid())
  subscriptionId String
  monto          Float
  estado         String   @default("pendiente")
  periodoInicio  DateTime
  periodoFin     DateTime
  creadoEn       DateTime @default(now())
}

// ============================================
// MÓDULO DE REPORTES COMUNITARIOS (FASE 2)
// ============================================

model Plataforma {
  id        String   @id @default(cuid())
  clave     String   @unique
  nombre    String
  categoria String   @default("otro")
  esActiva  Boolean  @default(true)
  creadoEn  DateTime @default(now())

  reportes           Reporte[]
  identificadores    IdentificadorReportado[]
  alertasSuscripcion AlertaSuscripcion[]
  apelaciones        ApelacionIdentificador[]
  contactosConfianza ContactoConfianza[]

  @@index([clave])
  @@index([esActiva])
}

model Pais {
  id       String   @id @default(cuid())
  codigo   String   @unique
  nombre   String
  esActivo Boolean  @default(true)
  creadoEn DateTime @default(now())

  ciudades Ciudad[]
  reportes Reporte[]

  @@index([codigo])
  @@index([esActivo])
}

model Ciudad {
  id       String   @id @default(cuid())
  nombre   String
  paisId   String
  lat      Float?
  lng      Float?
  esActivo Boolean  @default(true)
  creadoEn DateTime @default(now())

  pais     Pais      @relation(fields: [paisId], references: [id])
  reportes Reporte[]

  @@unique([nombre, paisId])
  @@index([paisId])
  @@index([esActivo])
}

model Reporte {
  id                 String             @id @default(cuid())
  identificador      String
  plataformaId       String
  texto              String             @db.Text
  textoOriginal      String?            @db.Text
  fechaIncidente     DateTime
  ciudad             String
  pais               String
  paisId             String?
  ciudadId           String?
  otraPlataforma     String?
  estado             EstadoReporte      @default(PENDIENTE)
  esAnonimo          Boolean            @default(true)
  edadVictima        Int?
  usuarioId          String?
  operadorId         String?
  reporteOrigenId    String?
  numeroSeguimiento  String?            @unique
  tenantId           String?
  processingError    String?            @db.Text
  prioridadAlta      Boolean            @default(false)
  keywordsDetectadas String[]
  esRafaga           Boolean            @default(false)
  fuenteConfianza    Float?
  eliminado          Boolean            @default(false)
  motivoBaja         MotivoBajaReporte?
  notaBaja           String?            @db.Text
  eliminadoEn        DateTime?
  eliminadoPorId     String?
  creadoEn           DateTime           @default(now())
  actualizadoEn      DateTime           @updatedAt

  plataforma    Plataforma        @relation(fields: [plataformaId], references: [id])
  usuario       Usuario?          @relation(fields: [usuarioId], references: [id])
  eliminadoPor  Usuario?          @relation(fields: [eliminadoPorId], references: [id], name: "ReportesDadosDeBaja")
  operador      Usuario?          @relation(fields: [operadorId], references: [id], name: "CasosOperador")
  reporteOrigen Reporte?          @relation("ReporteDuplicado", fields: [reporteOrigenId], references: [id])
  duplicados    Reporte[]         @relation("ReporteDuplicado")
  clasificacion ClasificacionIA?
  embedding     EmbeddingReporte?
  fuente        FuenteReporte?
  tenant        Tenant?           @relation(fields: [tenantId], references: [id])
  paisRel       Pais?             @relation(fields: [paisId], references: [id])
  ciudadRel     Ciudad?           @relation(fields: [ciudadId], references: [id])
  transiciones  TransicionReporte[]

  @@index([identificador, plataformaId])
  @@index([estado])
  @@index([usuarioId, identificador])
  @@index([creadoEn])
  @@index([numeroSeguimiento])
  @@index([paisId])
  @@index([ciudadId])
  @@index([eliminado])
  @@index([eliminadoPorId])
  @@index([operadorId])
}

model TransicionReporte {
  id               String                @id @default(cuid())
  reporteId        String
  estadoAnterior   EstadoReporte
  estadoNuevo      EstadoReporte
  responsableTipo  ResponsableTransicion
  responsableId    String?
  motivo           String?               @db.Text
  metadatos        Json?
  creadoEn         DateTime              @default(now())

  reporte            Reporte  @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  responsableUsuario Usuario? @relation(fields: [responsableId], references: [id], onDelete: SetNull)

  @@index([reporteId])
  @@index([responsableTipo])
  @@index([responsableId])
  @@index([creadoEn])
}

model FuenteReporte {
  id                   String   @id @default(cuid())
  reporteId            String   @unique
  ipHash               String?
  fingerprintHash      String?
  cuentaDiasAntiguedad Int?
  reportesPrevios      Int      @default(0)
  reportesConfirmados  Int      @default(0)
  reportesDescartados  Int      @default(0)
  pesoAplicado         Float
  creadoEn             DateTime @default(now())

  reporte Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)

  @@index([ipHash])
  @@index([fingerprintHash])
  @@index([creadoEn])
}

model IdentificadorReportado {
  id                    String    @id @default(cuid())
  identificador         String
  plataformaId          String
  totalReportes         Int       @default(0)
  reportesAutenticados  Int       @default(0)
  reportesAnonimos      Int       @default(0)
  esVisiblePublicamente Boolean   @default(false)
  score                 Int       @default(0)
  scoreAnonimo          Int       @default(0)
  scoreAutenticado      Int       @default(0)
  scoreAjustado         Int       @default(0)
  nivelRiesgo           String?
  ultimoReporteEn       DateTime?
  creadoEn              DateTime  @default(now())
  actualizadoEn         DateTime  @updatedAt

  plataforma  Plataforma               @relation(fields: [plataformaId], references: [id])
  apelaciones ApelacionIdentificador[]

  @@unique([identificador, plataformaId])
  @@index([esVisiblePublicamente])
  @@index([totalReportes])
  @@index([score])
}

model ApelacionIdentificador {
  id                    String          @id @default(cuid())
  identificador         String
  plataformaId          String
  tokenAcceso           String          @unique
  estado                EstadoApelacion @default(RECIBIDA)
  motivoSolicitud       String
  evidenciaUrl          String?
  respuestaAdmin        String?
  adminId               String?
  operadorId            String?
  tipoVerificacion      String // SMS | NICK
  contacto              String?
  smsCodigoHash         String?
  smsVerificado         Boolean         @default(false)
  smsIntentos           Int             @default(0)
  pausaHasta            DateTime?
  visibilidadRestaurada Boolean         @default(false)
  derechoApelar         Boolean         @default(true)
  notaRehabilitacion    String?
  creadoEn              DateTime        @default(now())
  actualizadoEn         DateTime        @updatedAt

  plataforma             Plataforma             @relation(fields: [plataformaId], references: [id])
  admin                  Usuario?               @relation(fields: [adminId], references: [id])
  operador               Usuario?               @relation(fields: [operadorId], references: [id], name: "ApelacionesOperador")
  identificadorReportado IdentificadorReportado @relation(fields: [identificador, plataformaId], references: [identificador, plataformaId])

  @@index([identificador, plataformaId])
  @@index([estado])
  @@index([tokenAcceso])
  @@index([operadorId])
}

model ContactoConfianza {
  id            String   @id @default(cuid())
  usuarioId     String
  identificador String
  plataformaId  String
  etiqueta      String?  @db.VarChar(100)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  usuario    Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  plataforma Plataforma @relation(fields: [plataformaId], references: [id])

  @@unique([usuarioId, identificador, plataformaId])
  @@index([usuarioId, activo])
  @@index([identificador, plataformaId])
}

model AlertaSuscripcion {
  id            String    @id @default(cuid())
  usuarioId     String
  identificador String
  plataformaId  String
  activa        Boolean   @default(true)
  ultimoEmailEn DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  plataforma Plataforma @relation(fields: [plataformaId], references: [id])

  @@unique([usuarioId, identificador, plataformaId])
  @@index([usuarioId])
  @@index([identificador, plataformaId])
  @@index([activa])
}

model ClasificacionIA {
  id                    String            @id @default(cuid())
  reporteId             String            @unique
  categoria             CategoriaConducta
  confianza             Float
  contienePii           Boolean           @default(false)
  piiDetectada          String[]
  modeloUsado           String
  latenciaMs            Int
  promptTokens          Int?
  responseTokens        Int?
  rawResponse           String?           @db.Text
  categoriasSecundarias Json?
  votos                 Json?
  usoCascada            Boolean           @default(false)
  modeloCascada         String?
  posibleAgresorPar     Boolean           @default(false)
  creadoEn              DateTime          @default(now())

  reporte    Reporte          @relation(fields: [reporteId], references: [id], onDelete: Cascade)
  correccion CorreccionAdmin?

  @@index([categoria])
  @@index([confianza])
}

model CorreccionAdmin {
  id                 String            @id @default(cuid())
  clasificacionId    String            @unique
  categoriaOriginal  CategoriaConducta
  categoriaCorregida CategoriaConducta
  adminId            String
  motivo             String?           @db.Text
  confirmada         Boolean           @default(false)
  creadoEn           DateTime          @default(now())

  clasificacion    ClasificacionIA        @relation(fields: [clasificacionId], references: [id], onDelete: Cascade)
  admin            Usuario                @relation(fields: [adminId], references: [id])
  datasetRegistros DatasetEntrenamiento[]
}

model DatasetEntrenamiento {
  id                     String            @id @default(cuid())
  texto                  String            @db.Text
  clasificacionCorrecta  CategoriaConducta
  fuente                 String
  correccionId           String?
  usadoParaEntrenamiento Boolean           @default(false)
  textoAnonimizado       Boolean           @default(false)
  creadoEn               DateTime          @default(now())

  correccion CorreccionAdmin?  @relation(fields: [correccionId], references: [id])
  embedding  EmbeddingDataset?

  @@index([usadoParaEntrenamiento])
}

model EmbeddingDataset {
  id          String                     @id @default(cuid())
  datasetId   String                     @unique
  // Índice hnsw sobre vector creado por migración SQL manual (20260717002004_add_pgvector_hnsw_indexes).
  // Prisma no lo gestiona; verificar que exista tras cada migrate deploy.
  vector      Unsupported("vector(768)")
  modeloUsado String
  creadoEn    DateTime                   @default(now())

  dataset DatasetEntrenamiento @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model EmbeddingReporte {
  id          String                     @id @default(cuid())
  reporteId   String                     @unique
  // Índice hnsw sobre vector creado por migración SQL manual (20260717002004_add_pgvector_hnsw_indexes).
  // Prisma no lo gestiona; verificar que exista tras cada migrate deploy.
  vector      Unsupported("vector(768)")
  modeloUsado String
  creadoEn    DateTime                   @default(now())

  reporte Reporte @relation(fields: [reporteId], references: [id], onDelete: Cascade)
}

model RateLimit {
  key           String   @id
  scope         String
  identifier    String
  windowStart   DateTime
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([scope, identifier, windowStart])
}

enum CasoEvalFuente {
  SEMILLA
  MANUAL_ADMIN
  PRODUCCION_ANONIMIZADO
}

model CasoEval {
  id                 String         @id @default(cuid())
  texto              String         @db.Text
  categoriaEsperada  String
  secundariaEsperada String?
  ruido              Boolean        @default(false)
  fuente             CasoEvalFuente @default(SEMILLA)
  activo             Boolean        @default(true)
  fixtureVersion     Int            @default(1)
  creadoPorId        String?
  creadoEn           DateTime       @default(now())

  creadoPor  Usuario?        @relation(fields: [creadoPorId], references: [id])
  resultados EvalResultado[]

  @@index([categoriaEsperada])
  @@index([fuente])
  @@index([activo])
  @@index([fixtureVersion])
}

enum EvalRunEstado {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  FALLIDA
  CANCELADA
}

model EvalRun {
  id             String        @id @default(cuid())
  tipo           String        @default("f7")
  fixtureVersion Int
  estado         EvalRunEstado @default(PENDIENTE)
  iniciadoEn     DateTime      @default(now())
  finalizadoEn   DateTime?
  resultadoJson  Json?
  error          String?       @db.Text
  creadoPorId    String?

  // Spec 014 — Laboratorio de experimentos
  nombre         String?
  notas          String? @db.Text
  configSnapshot Json?
  progresoCasos  Int     @default(0)
  progresoTotal  Int     @default(0)

  creadoPor  Usuario?        @relation(fields: [creadoPorId], references: [id])
  resultados EvalResultado[]

  @@index([estado])
  @@index([fixtureVersion])
  @@index([creadoPorId])
}

model EvalResultado {
  id            String   @id @default(cuid())
  experimentoId String
  casoEvalId    String
  esperado      String
  predicho      String
  confianza     Float
  estadoFinal   String
  correcto      Boolean
  latenciaMs    Int
  creadoEn      DateTime @default(now())

  experimento EvalRun  @relation(fields: [experimentoId], references: [id], onDelete: Cascade)
  casoEval    CasoEval @relation(fields: [casoEvalId], references: [id], onDelete: Cascade)

  @@index([experimentoId])
  @@index([casoEvalId])
  @@index([correcto])
  @@index([esperado])
}
