# ─────────────────────────────────────────────────────────────────────────────
# 003-2026-SICOV-OTPC — plantilla de variables de entorno.
# Copia a .env (y .env.test para tests). NUNCA commitear el .env real (repo público).
# Los secretos reales de Supertransporte viven SOLO local (nunca en el repo, que es
# público). Por decisión del CEO (acta CE-01 / DE-03) NO se rotan: son claves asignadas
# por la Super, no emitidas por IDC. Ver constitución §1.3 / §1.4.
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos (Docker propio del 003, puerto 5434, esquema sicov)
DATABASE_URL="postgresql://sicov:sicov_dev@127.0.0.1:5434/sicov?schema=sicov"
DB_USER="sicov"
DB_PASSWORD="sicov_dev"
DB_NAME="sicov"

# Sesión / JWT interno (mínimo 32 caracteres)
JWT_SECRET="cambiar-en-produccion-minimo-32-caracteres-largo"
COOKIE_SECURE="false"          # true en HTTPS; en LAN/local dejar false

# Worker de cola (pg-boss). Secreto para el endpoint interno worker→API.
WORKER_SECRET="cambiar-en-produccion-al-menos-32-caracteres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:5010"
API_BASE_URL="http://localhost:5010"

# ── Integración Supertransporte ──────────────────────────────────────────────
# GUARDARRAÍL: por defecto STUB. El cliente real (que consume las APIs productivas)
# SOLO se activa con AMBAS: INTEGRACIONES_MODO=real Y SUPERTRANSPORTE_HABILITADO=true
# Y credenciales presentes. No activar hasta verificación/aprobación humana.
INTEGRACIONES_MODO="stub"              # stub | real   (default: stub)
SUPERTRANSPORTE_HABILITADO="false"     # gate explícito adicional para modo real

# Credenciales de proveedor (Gesmovil) — vacías en repo; llenar SOLO en .env local.
EXTERNAL_APP_USER=""
EXTERNAL_APP_PASSWORD=""

# Login del proveedor: de aquí sale el token Bearer (cabecera 1 del doble token).
# Sin esta variable NO se puede obtener el token de proveedor (requireEnv falla).
EXTERNAL_APP_LOGIN_URL="https://sisntback.supertransporte.gov.co/api/v1/autenticacion/inicio-sesion"

# Endpoints externos (URLs públicas, no secretas). Solo se usan en modo real.
URL_DESPACHOS="https://sicovreportes.supertransporte.gov.co/despachoback/api/v1"

# ⚠️ URL_INTEGRADORA = SOLO EL HOST BASE, sin ruta.
# El código añade "/api-integradora/resumen" (cliente-http.ts). Si aquí se pone la
# URL completa se genera una ruta DUPLICADA y la petición falla (404).
# El .env del legacy en producción trae la URL completa → ese bug existe allá; no replicarlo.
URL_INTEGRADORA="https://sicovintegradora.supertransporte.gov.co"
TIMEOUT_INTEGRADORA_MS="100000"        # opcional; default 100 s

# Maestras (rutas activas, autorizaciones). Base + token estático Bearer.
URL_MATENIMIENTOS="https://rutasback.supertransporte.gov.co/api/v2"   # (typo heredado del legacy)
TOKEN=""                               # token estático Bearer para maestras (solo local)
TOKEN_PARAMETRICO=""                   # token estático para paramétricas (solo local)

# Zona horaria del dominio
TZ="America/Bogota"

# Cola de reportes (D-019b): reintentos y backoff parametrizables, compartidos por las 3 colas
# (despachos, llegadas, mantenimientos). Defaults si no se definen: 3 reintentos, 5 minutos.
COLA_MAX_REINTENTOS="3"
COLA_BACKOFF_MIN="5"
