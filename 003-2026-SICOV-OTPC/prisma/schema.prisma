// Esquema Prisma del 003-SICOV-OTPC — mapea 1:1 el esquema `sicov` real del legacy.
// Alcance P1: 13 tablas del core (auth + autorización por módulos + doble token + cola).
// Columnas verificadas contra legacy-sistema-original/back_gestion_despachos/database/migrations.
// Migraciones ADITIVAS; nunca `migrate reset`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["sicov"]
}

/// Catálogo de roles. Valores canónicos por seed: 1 admin, 2 cliente, 3 operador.
model Rol {
  id           Int      @id @default(autoincrement()) @map("rol_id")
  nombre       String?  @map("rol_nombre") @db.VarChar(30)
  estado       Boolean? @map("rol_estado")
  root         Boolean? @default(false) @map("rol_root")
  creado       DateTime? @default(now()) @map("rol_creado") @db.Timestamptz()
  actualizado  DateTime? @default(now()) @map("rol_actualizado") @db.Timestamptz()

  usuarios     Usuario[]
  rolesModulos RolModulo[]
  rmf          RolModuloFuncionalidad[]

  @@map("tbl_roles")
  @@schema("sicov")
}

/// Usuarios del sistema. Login único usuario/contraseña.
/// `administradorId` (usn_administrador) guarda la IDENTIFICACIÓN del admin (join lógico a
/// usn_identificacion), no un usn_id — por eso NO se declara relación Prisma self.
model Usuario {
  id              Int       @id @default(autoincrement()) @map("usn_id")
  nombre          String    @map("usn_nombre") @db.VarChar(200)
  identificacion  String?   @unique @map("usn_identificacion") @db.VarChar(255)
  usuario         String?   @unique @map("usn_usuario") @db.VarChar(255)
  clave           String?   @map("usn_clave") @db.VarChar(255)
  claveTemporal   Boolean?  @default(true) @map("usn_clave_temporal")
  telefono        String?   @map("usn_telefono") @db.VarChar(255)
  correo          String?   @map("usn_correo") @db.VarChar(255)
  tokenAutorizado String?   @map("usn_token_autorizado") @db.VarChar(255)
  rolId           Int?      @map("usn_rol_id")
  administradorId Int?      @map("usn_administrador")
  estado          Boolean?  @default(true) @map("usn_estado")
  creacion        DateTime? @map("usn_creacion") @db.Timestamptz()
  actualizacion   DateTime? @map("usn_actualizacion") @db.Timestamptz()

  rol             Rol?            @relation(fields: [rolId], references: [id])
  usuariosModulos UsuarioModulo[]

  @@index([rolId])
  @@index([administradorId])
  @@index([estado])
  @@map("tbl_usuarios")
  @@schema("sicov")
}

/// Módulos del menú lateral data-driven.
model Modulo {
  id            Int       @id @default(autoincrement()) @map("mod_id")
  nombre        String?   @map("mod_nombre") @db.VarChar(30)
  nombreMostrar String?   @map("mod_nombre_mostrar") @db.VarChar(30)
  ruta          String?   @map("mod_ruta") @db.VarChar(100)
  orden         Int?      @map("mod_orden")
  icono         String?   @map("mod_icono") @db.VarChar(255)
  estado        Boolean?  @map("mod_estado")
  creado        DateTime? @default(now()) @map("mod_creado") @db.Timestamptz()
  actualizado   DateTime? @default(now()) @map("mod_actualizado") @db.Timestamptz()

  submodulos      Submodulo[]
  rolesModulos    RolModulo[]
  rmf             RolModuloFuncionalidad[]
  usuariosModulos UsuarioModulo[]

  @@map("tbl_modulos")
  @@schema("sicov")
}

model Submodulo {
  id            Int       @id @default(autoincrement()) @map("smod_id")
  nombre        String?   @map("smod_nombre") @db.VarChar(30)
  nombreMostrar String?   @map("smod_nombre_mostrar") @db.VarChar(30)
  ruta          String?   @map("smod_ruta") @db.VarChar(100)
  moduloId      Int?      @map("smod_modulo")
  icono         String?   @map("smod_icono") @db.VarChar(255)
  estado        Boolean?  @default(true) @map("smod_estado")
  creado        DateTime? @default(now()) @map("smod_creado") @db.Timestamptz()
  actualizado   DateTime? @default(now()) @map("smod_actualizado") @db.Timestamptz()

  modulo          Modulo?         @relation(fields: [moduloId], references: [id])
  usuariosModulos UsuarioModulo[]

  @@map("tbl_submodulos")
  @@schema("sicov")
}

model Funcionalidad {
  id          Int       @id @default(autoincrement()) @map("fun_id")
  nombre      String?   @map("fun_nombre") @db.VarChar(30)
  estado      Boolean?  @map("fun_estado")
  creado      DateTime? @default(now()) @map("fun_creado") @db.Timestamptz()
  actualizado DateTime? @default(now()) @map("fun_actualizado") @db.Timestamptz()

  rmf RolModuloFuncionalidad[]

  @@map("tbl_funcionalidades")
  @@schema("sicov")
}

model RolModulo {
  id          Int       @id @default(autoincrement()) @map("rom_id")
  rolId       Int?      @map("rom_rol_id")
  moduloId    Int?      @map("rom_modulo_id")
  creado      DateTime? @default(now()) @map("rom_creado") @db.Timestamptz()
  actualizado DateTime? @default(now()) @map("rom_actualizado") @db.Timestamptz()

  rol    Rol?    @relation(fields: [rolId], references: [id])
  modulo Modulo? @relation(fields: [moduloId], references: [id])

  @@map("tbl_roles_modulos")
  @@schema("sicov")
}

model RolModuloFuncionalidad {
  id             Int       @id @default(autoincrement()) @map("rmf_id")
  rolId          Int?      @map("rmf_rol_id")
  moduloId       Int?      @map("rmf_modulo_id")
  funcionalidadId Int?     @map("rmf_funcionalidad_id")
  creado         DateTime? @map("rmf_creado") @db.Timestamptz()
  actualizado    DateTime? @map("rmf_actualizado") @db.Timestamptz()

  rol           Rol?           @relation(fields: [rolId], references: [id])
  modulo        Modulo?        @relation(fields: [moduloId], references: [id])
  funcionalidad Funcionalidad? @relation(fields: [funcionalidadId], references: [id])

  @@map("tbl_roles_modulos_funcionalidades")
  @@schema("sicov")
}

model UsuarioModulo {
  id          Int       @id @default(autoincrement()) @map("usm_id")
  usuarioId   Int?      @map("usm_usuario_id")
  moduloId    Int?      @map("usm_modulo_id")
  submoduloId Int?      @map("usm_submodulo_id") // ADITIVA (B1). NULL = módulo completo
  estado      Boolean?  @default(true) @map("usm_estado")
  creado      DateTime? @default(now()) @map("usm_creado") @db.Timestamptz()
  actualizado DateTime? @default(now()) @map("usm_actualizado") @db.Timestamptz()

  usuario   Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  modulo    Modulo?    @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  submodulo Submodulo? @relation(fields: [submoduloId], references: [id], onDelete: Cascade)

  // SIN @@unique de Prisma: la unicidad va por DOS índices únicos PARCIALES en el SQL manual (B1).
  // En PostgreSQL los NULL son distintos entre sí, así que un @@unique de 3 columnas admitiría
  // dos filas (u, m, NULL) — se pierde la unicidad del "módulo completo". Ver migración manual.
  @@index([submoduloId])
  @@map("tbl_usuarios_modulos")
  @@schema("sicov")
}

/// Bloqueo por intentos fallidos de login (tabla real: tbl_bloqueo_usuarios).
model BloqueoUsuario {
  id               Int       @id @default(autoincrement()) @map("blu_id")
  identificacion   String?   @unique @map("blu_identificacion") @db.VarChar(255)
  intentosFallidos Int?      @default(0) @map("blu_intentos_fallidos")
  bloqueado        Boolean?  @default(false) @map("blu_bloqueado")
  ultimoIntento    DateTime? @map("blu_ultimo_intento") @db.Timestamptz()
  actualizacion    DateTime? @default(now()) @map("blu_actualizacion") @db.Timestamptz()
  creacion         DateTime? @default(now()) @map("blu_creacion") @db.Timestamptz()

  @@map("tbl_bloqueo_usuarios")
  @@schema("sicov")
}

/// Proveedores vigilados: empresa + vigencia contractual (validada antes de reportar).
model ProveedorVigilado {
  id             Int       @id @default(autoincrement()) @map("tpv_id")
  empresa        String?   @map("tpv_empresa") @db.VarChar(255)
  vigilado       String?   @map("tpv_vigilado") @db.VarChar(255)
  token          String?   @map("tpv_token") @db.Uuid
  estado         Boolean?  @default(true) @map("tpv_estado")
  fechaInicial   DateTime? @map("tpv_fecha_inicial") @db.Date
  fechaFinal     DateTime? @map("tpv_fecha_final") @db.Date
  documento      String?   @map("tpv_documento") @db.VarChar(255)
  ruta           String?   @map("tpv_ruta") @db.VarChar(255)
  nombreOriginal String?   @map("tpv_nombre_original") @db.VarChar(255)
  createdAt      DateTime? @default(now()) @map("tpv_created_at") @db.Timestamptz()
  updatedAt      DateTime? @default(now()) @map("tpv_updated_at") @db.Timestamptz()

  @@index([documento])
  @@index([estado])
  @@map("tbl_proveedores_vigilados")
  @@schema("sicov")
}

/// Cola de despachos (worker table-driven). Estados: pendiente|procesando|procesado|fallido.
model DespachoSolicitud {
  id                Int       @id @default(autoincrement()) @map("des_sol_id")
  payload           Json      @map("des_sol_payload") @db.Json
  nitVigilado       String    @map("des_sol_nit_vigilado") @db.VarChar(20)
  usuarioId         String    @map("des_sol_usuario_id") @db.VarChar(20)
  fuente            String    @default("WEB") @map("des_sol_fuente") @db.VarChar(10)
  procesado         Boolean   @default(false) @map("des_sol_procesado")
  idDespachoExterno Int?      @map("des_sol_id_despacho_externo")
  respuestaExterna  Json?     @map("des_sol_respuesta_externa") @db.Json
  errorExterno      String?   @map("des_sol_error_externo") @db.Text
  estado            String    @default("pendiente") @map("des_sol_estado") @db.VarChar(30)
  reintentos        Int       @default(0) @map("des_sol_reintentos")
  rolId             Int?      @map("des_sol_rol_id")
  siguienteIntento  DateTime? @default(now()) @map("des_sol_siguiente_intento") @db.Timestamptz()
  fechaCreacion     DateTime? @default(now()) @map("des_sol_fecha_creacion") @db.Timestamptz()
  fechaActualizacion DateTime? @default(now()) @map("des_sol_fecha_actualizacion") @db.Timestamptz()

  @@index([estado, siguienteIntento], map: "des_sol_estado_intento_idx")
  @@index([nitVigilado])
  @@map("tbl_despachos_solicitudes")
  @@schema("sicov")
}

/// Cola de llegadas. Columnas base verificadas vs legacy; las de cola (estado/reintentos/
/// siguienteIntento/rolId) NO existen en el legacy → se añaden ADITIVAMENTE en el 003.
model LlegadaSolicitud {
  id                 Int       @id @default(autoincrement()) @map("lle_sol_id")
  payload            Json      @map("lle_sol_payload") @db.Json
  nitVigilado        String    @map("lle_sol_nit_vigilado") @db.VarChar(20)
  usuarioId          String    @map("lle_sol_usuario_id") @db.VarChar(20)
  fuente             String    @default("WEB") @map("lle_sol_fuente") @db.VarChar(10)
  tipoLlegada        Int       @map("lle_sol_tipo_llegada")
  idDespacho         Int?      @map("lle_sol_id_despacho")
  placa              String    @map("lle_sol_placa") @db.VarChar(10)
  procesado          Boolean   @default(false) @map("lle_sol_procesado")
  idLlegadaExterno   Int?      @map("lle_sol_id_llegada_externo")
  respuestaExterna   Json?     @map("lle_sol_respuesta_externa") @db.Json
  errorExterno       String?   @map("lle_sol_error_externo") @db.Text
  // --- columnas de cola añadidas aditivamente por el 003 ---
  estado             String    @default("pendiente") @map("lle_sol_estado") @db.VarChar(30)
  reintentos         Int       @default(0) @map("lle_sol_reintentos")
  rolId              Int?      @map("lle_sol_rol_id")
  siguienteIntento   DateTime? @default(now()) @map("lle_sol_siguiente_intento") @db.Timestamptz()
  fechaCreacion      DateTime? @default(now()) @map("lle_sol_fecha_creacion") @db.Timestamptz()
  fechaActualizacion DateTime? @default(now()) @map("lle_sol_fecha_actualizacion") @db.Timestamptz()

  @@index([estado, siguienteIntento], map: "lle_sol_estado_intento_idx")
  @@index([nitVigilado])
  @@map("tbl_llegadas_solicitudes")
  @@schema("sicov")
}

model Estado {
  id     Int      @id @default(autoincrement()) @map("est_id")
  nombre String?  @map("est_nombre") @db.VarChar(150)
  estado Boolean? @default(true) @map("est_estado")

  @@map("tbl_estados")
  @@schema("sicov")
}

/// Catálogo de tipos de mantenimiento (1=Preventivo, 2=Correctivo, 3=Alistamiento, 4=Autorización).
model TipoMantenimiento {
  id          Int       @id @default(autoincrement()) @map("ttm_id")
  nombre      String?   @map("ttm_nombre") @db.VarChar(150)
  estado      Boolean?  @default(true) @map("ttm_estado")
  creado      DateTime? @default(now()) @map("ttm_creado") @db.Timestamptz()
  actualizado DateTime? @default(now()) @map("ttm_actualizado") @db.Timestamptz()

  archivos ArchivoPrograma[]

  @@map("tbl_tipo_mantenimientos")
  @@schema("sicov")
}

/// PDF del programa de mantenimiento por tipo y vigilado (la gestión de archivos llega en 005-B).
model ArchivoPrograma {
  id             Int       @id @default(autoincrement()) @map("tap_id")
  nombreOriginal String?   @map("tap_nombre_original") @db.VarChar(200)
  documento      String?   @map("tap_documento") @db.VarChar(200)
  ruta           String?   @map("tap_ruta") @db.VarChar(200)
  tipoId         Int?      @map("tap_tipo_id")
  usuarioId      Int?      @map("tap_usuario_id")
  estado         Boolean?  @default(true) @map("tap_estado")
  creado         DateTime? @default(now()) @map("tap_creado") @db.Timestamptz()
  actualizado    DateTime? @default(now()) @map("tap_actualizado") @db.Timestamptz()

  tipo TipoMantenimiento? @relation(fields: [tipoId], references: [id], onDelete: Cascade)

  @@index([usuarioId, tipoId])
  @@map("tbl_archivo_programas")
  @@schema("sicov")
}

/// Cabecera base placa+tipo+vigilado. usuarioId guarda el NIT del vigilado (paridad legacy;
/// BigInt por ser NIT). mantenimientoIdExterno = id devuelto por la Super — SEPARADO del id local.
model Mantenimiento {
  id                     Int       @id @default(autoincrement()) @map("tmt_id")
  placa                  String?   @map("tmt_placa") @db.VarChar(6)
  fechaDiligenciamiento  DateTime? @map("tmt_fecha_diligenciamiento") @db.Timestamptz()
  tipoId                 Int?      @map("tmt_tipo_id")
  usuarioId              BigInt?   @map("tmt_usuario_id")
  estado                 Boolean?  @default(true) @map("tmt_estado")
  procesado              Boolean?  @default(false) @map("tmt_procesado")
  mantenimientoIdExterno Int?      @map("tmt_mantenimiento_id")
  creado                 DateTime? @default(now()) @map("tmt_creado") @db.Timestamptz()
  actualizado            DateTime? @default(now()) @map("tmt_actualizado") @db.Timestamptz()

  @@index([usuarioId, placa, tipoId])
  @@index([procesado])
  @@map("tbl_mantenimientos")
  @@schema("sicov")
}

/// Detalle preventivo. mantenimientoId = enlace LOCAL al base (nunca se sobrescribe);
/// mantenimientoIdExterno = columna ADITIVA 003 con el id de la Super (gate B1).
model Preventivo {
  id                     Int       @id @default(autoincrement()) @map("tpv_id")
  placa                  String?   @map("tpv_placa") @db.VarChar(6)
  fecha                  DateTime? @map("tpv_fecha") @db.Date
  hora                   String?   @map("tpv_hora") @db.VarChar(8)
  nit                    BigInt?   @map("tpv_nit")
  razonSocial            String?   @map("tpv_razon_social") @db.VarChar(200)
  tipoIdentificacion     Int?      @map("tpv_tipo_identificacion")
  numeroIdentificacion   String?   @map("tpv_numero_identificacion") @db.VarChar(255)
  nombresResponsable     String?   @map("tpv_nombres_responsable") @db.VarChar(255)
  mantenimientoId        Int?      @map("tpv_mantenimiento_id")
  mantenimientoIdExterno Int?      @map("tpv_mantenimiento_id_externo")
  detalleActividades     String?   @map("tpv_detalle_actividades") @db.Text
  estado                 Boolean?  @default(true) @map("tpv_estado")
  procesado              Boolean?  @default(false) @map("tpv_procesado")
  creado                 DateTime? @default(now()) @map("tpv_creado") @db.Timestamptz()
  actualizado            DateTime? @default(now()) @map("tpv_actualizado") @db.Timestamptz()

  @@index([mantenimientoId])
  @@index([procesado])
  @@map("tbl_preventivos")
  @@schema("sicov")
}

/// Detalle correctivo — espejo de Preventivo con prefijo tcv_.
model Correctivo {
  id                     Int       @id @default(autoincrement()) @map("tcv_id")
  placa                  String?   @map("tcv_placa") @db.VarChar(6)
  fecha                  DateTime? @map("tcv_fecha") @db.Date
  hora                   String?   @map("tcv_hora") @db.VarChar(8)
  nit                    BigInt?   @map("tcv_nit")
  razonSocial            String?   @map("tcv_razon_social") @db.VarChar(200)
  tipoIdentificacion     Int?      @map("tcv_tipo_identificacion")
  numeroIdentificacion   String?   @map("tcv_numero_identificacion") @db.VarChar(255)
  nombresResponsable     String?   @map("tcv_nombres_responsable") @db.VarChar(200)
  mantenimientoId        Int?      @map("tcv_mantenimiento_id")
  mantenimientoIdExterno Int?      @map("tcv_mantenimiento_id_externo")
  detalleActividades     String?   @map("tcv_detalle_actividades") @db.Text
  estado                 Boolean?  @default(true) @map("tcv_estado")
  procesado              Boolean?  @default(false) @map("tcv_procesado")
  creado                 DateTime? @default(now()) @map("tcv_creado") @db.Timestamptz()
  actualizado            DateTime? @default(now()) @map("tcv_actualizado") @db.Timestamptz()

  @@index([mantenimientoId])
  @@index([procesado])
  @@map("tbl_correctivos")
  @@schema("sicov")
}

/// Cola de sincronización de mantenimientos. Tipos: base|preventivo|correctivo (005) +
/// alistamiento|autorizacion reservados para 006/007 (varchar validado en app, no enum PG).
model MantenimientoJob {
  id                   Int       @id @default(autoincrement()) @map("tmj_id")
  tipo                 String    @map("tmj_tipo") @db.VarChar(20)
  mantenimientoLocalId Int?      @map("tmj_mantenimiento_local_id")
  detalleId            Int?      @map("tmj_detalle_id")
  vigiladoId           String    @map("tmj_vigilado_id") @db.VarChar(30)
  usuarioDocumento     String    @map("tmj_usuario_documento") @db.VarChar(30)
  rolId                Int       @map("tmj_rol_id")
  estado               String    @default("pendiente") @map("tmj_estado") @db.VarChar(30)
  reintentos           Int       @default(0) @map("tmj_reintentos")
  ultimoError          String?   @map("tmj_ultimo_error") @db.Text
  siguienteIntento     DateTime? @default(now()) @map("tmj_siguiente_intento") @db.Timestamptz()
  payload              Json?     @map("tmj_payload") @db.Json
  creado               DateTime? @default(now()) @map("tmj_creado") @db.Timestamptz()
  actualizado          DateTime? @default(now()) @map("tmj_actualizado") @db.Timestamptz()

  @@index([estado, siguienteIntento], map: "tmj_estado_intento_idx")
  @@index([vigiladoId])
  @@index([mantenimientoLocalId])
  @@map("tbl_mantenimiento_jobs")
  @@schema("sicov")
}

/// Registro de errores (tabla real: tbl_logs_errores).
model LogError {
  id         Int       @id @default(autoincrement()) @map("log_id")
  mensaje    String    @map("log_mensaje") @db.VarChar(1024)
  stackTrace String?   @map("log_stack_trace") @db.Text
  usuario    String?   @map("log_usuario") @db.VarChar(255)
  endpoint   String?   @map("log_endpoint") @db.VarChar(255)
  creacion   DateTime? @default(now()) @map("log_creacion") @db.Timestamptz()

  @@map("tbl_logs_errores")
  @@schema("sicov")
}

/// Bitácora de la consola de APIs (spec 013). Tabla NUEVA propia del 003 (prefijo apl_, no
/// existe en el legacy). Fase 1: todas las filas modo="stub". request/respuesta en jsonb,
/// REDACTADAS de forma recursiva y truncadas antes de persistir (nunca tokens, solo nombres).
model ApiLlamada {
  id          Int       @id @default(autoincrement()) @map("apl_id")
  usuarioId   Int       @map("apl_usuario_id")
  rolId       Int?      @map("apl_rol_id")
  nitEfectivo String?   @map("apl_nit_efectivo") @db.VarChar(30)
  operacion   String    @map("apl_operacion") @db.VarChar(60)
  modo        String    @map("apl_modo") @db.VarChar(10) // stub | real
  metodo      String?   @map("apl_metodo") @db.VarChar(10)
  endpoint    String?   @map("apl_endpoint") @db.VarChar(255) // path externo declarado (no secreto)
  request     Json?     @map("apl_request") @db.JsonB // REDACTADO recursivo + truncado
  respuesta   Json?     @map("apl_respuesta") @db.JsonB // truncada
  status      Int?      @map("apl_status")
  duracionMs  Int?      @map("apl_duracion_ms")
  error       String?   @map("apl_error") @db.Text
  creado      DateTime? @default(now()) @map("apl_creado") @db.Timestamptz()

  @@index([creado])
  @@index([operacion])
  @@index([modo])
  @@map("tbl_api_llamadas")
  @@schema("sicov")
}
